{
	"compilerOptions": {
		"target": "ES2019",
		"module": "CommonJS",
		"lib": ["ES2019"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"declaration": false,
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"include": ["src", "__tests__"]
}
